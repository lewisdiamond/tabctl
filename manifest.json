{
    "manifest_version": 3,
    "name": "tabctl",
    "version": "0.1.0",
    "description": "Control browser tabs from the command line",
    "permissions": [
        "tabs",
        "nativeMessaging",
        "windows",
        "favicon"
    ],
    "background": {
        "service_worker": "dist/background.js",
        "scripts": [
            "dist/background.js"
        ]
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "tabctl@localhost",
            "strict_min_version": "109.0"
        }
    }
}
